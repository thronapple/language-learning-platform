.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.error-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  background: #fff;
  border: 2rpx solid #667eea;
  border-radius: 40rpx;
  line-height: 1;
}

.retry-btn::after {
  border: none;
}
