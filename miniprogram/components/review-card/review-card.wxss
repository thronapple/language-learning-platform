.card {
  background: var(--paper);
  padding: 24rpx;
  border: 2rpx solid var(--ink-100);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-xs);
}

.word {
  color: var(--ink-900);
  font-size: 36rpx;
  font-weight: 900;
}

.meaning {
  margin: 12rpx 0;
  color: var(--ink-600);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.ops {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}
