.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 32rpx 40rpx;
  padding: 72rpx 48rpx;
  background: var(--paper);
  border: 2rpx solid var(--ink-100);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.empty-mark {
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--brand-100);
}

.empty-icon {
  font-size: 64rpx;
  line-height: 1;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--ink-900);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--ink-500);
  text-align: center;
  line-height: 1.6;
  font-weight: 700;
}

.empty-action {
  margin-top: 32rpx;
  min-width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 48rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #fff;
  background: var(--brand-500);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 6rpx 0 var(--brand-700), var(--shadow-xs);
}

.empty-action::after {
  border: none;
}
