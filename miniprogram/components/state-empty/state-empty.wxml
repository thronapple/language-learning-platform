<view class="empty">
  <view class="empty-mark">
    <view class="empty-icon">{{icon}}</view>
  </view>
  <view class="empty-title">{{title}}</view>
  <view class="empty-desc" wx:if="{{desc}}">{{desc}}</view>
  <button
    class="empty-action"
    wx:if="{{actionText}}"
    bindtap="onAction"
  >{{actionText}}</button>
</view>
