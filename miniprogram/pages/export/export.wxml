<view class="page">
  <view class="header">
    <view class="header-title">学习成果分享</view>
    <view class="header-sub">生成学习成果长图，分享给好友</view>
  </view>

  <view class="content">
    <view class="preview-card" wx:if="{{url}}">
      <image class="preview-image" mode="widthFix" src="{{url}}" />
    </view>

    <view class="placeholder-card" wx:else>
      <view class="placeholder-icon">🖼️</view>
      <view class="placeholder-text">点击下方按钮生成长图</view>
    </view>

    <button
      class="gen-btn"
      bindtap="generate"
      loading="{{generating}}"
      disabled="{{generating}}"
    >
      {{generating ? '生成中...' : '生成长图'}}
    </button>

    <button class="save-btn" wx:if="{{url}}" bindtap="save">
      保存到相册
    </button>
  </view>
</view>
