.page {
  min-height: 100vh;
  background: #f5f7fa;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 40rpx 48rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.content {
  padding: 32rpx;
}

.preview-card {
  background: white;
  border-radius: 20rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  margin-bottom: 24rpx;
}

.preview-image {
  width: 100%;
  border-radius: 12rpx;
}

.placeholder-card {
  background: white;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  margin-bottom: 24rpx;
}

.placeholder-icon {
  font-size: 80rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999;
}

.gen-btn {
  width: 100%;
  height: 92rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 46rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
  margin-bottom: 16rpx;
}

.gen-btn::after {
  border: none;
}

.gen-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.save-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
  background: #fff;
  border: 2rpx solid #667eea;
  border-radius: 46rpx;
  padding: 0;
}

.save-btn::after {
  border: none;
}
