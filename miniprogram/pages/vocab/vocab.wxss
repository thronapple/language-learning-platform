.page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 顶部区域 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx 32rpx 24rpx;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 76rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.add-btn {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 32rpx;
  background: rgba(255, 255, 255, 0.25);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.add-btn::after {
  border: none;
}

.add-btn[disabled] {
  opacity: 0.4;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 8rpx;
}

.filter-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon-large {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 词汇列表 */
.word-list {
  padding: 20rpx 32rpx;
}

.word-card {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.word-main {
  margin-bottom: 20rpx;
}

.word-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.word-meaning {
  font-size: 26rpx;
  color: #667eea;
  line-height: 1.5;
}

.word-hint {
  font-size: 26rpx;
  color: #ccc;
}

.word-meta {
  min-height: 40rpx;
}

/* SRS 评分 */
.rate-row {
  display: flex;
  gap: 12rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f2f5;
}

.rate-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.rate-btn:active {
  transform: scale(0.95);
}

.rate-btn.again { background: #fff0f0; }
.rate-btn.hard { background: #fff8e6; }
.rate-btn.good { background: #f0fff4; }
.rate-btn.easy { background: #f0f0ff; }

.rate-emoji {
  font-size: 32rpx;
}

.rate-label {
  font-size: 20rpx;
  color: #666;
  font-weight: 500;
}

/* 移除 */
.remove-row {
  text-align: right;
  padding-top: 12rpx;
}

.remove-link {
  font-size: 24rpx;
  color: #ccc;
}
