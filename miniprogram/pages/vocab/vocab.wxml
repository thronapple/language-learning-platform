<view class="vocab-page">
  <view class="review-top">
    <view class="back-btn" bindtap="goHome"></view>
    <view class="progress-wrap">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{items.length > 0 ? (activeIndex + 1) * 100 / items.length : 0}}%;"></view>
      </view>
    </view>
    <view class="progress-count t-mono">
      <text class="current">{{items.length > 0 ? activeIndex + 1 : 0}}</text>/<text>{{items.length}}</text>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-chip mint"><view class="dot"></view>记得 {{rememberedCount}}</view>
    <view class="stat-chip lemon"><view class="dot"></view>模糊 {{fuzzyCount}}</view>
    <view class="stat-chip coral"><view class="dot"></view>忘了 {{forgottenCount}}</view>
  </view>

  <view class="search-panel">
    <view class="search-input-wrap">
      <view class="search-icon"></view>
      <input
        class="search-input"
        placeholder="搜索或添加新单词"
        value="{{word}}"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="add"
      />
    </view>
    <button class="add-btn" bindtap="add" disabled="{{!word}}">添加</button>
  </view>

  <view class="filter-row">
    <view class="filter-chip {{!onlyDue ? 'active' : ''}}" data-only-due="false" bindtap="setFilter">全部</view>
    <view class="filter-chip {{onlyDue ? 'active' : ''}}" data-only-due="true" bindtap="setFilter">仅待复习</view>
  </view>

  <skeleton type="list" wx:if="{{loading}}" />
  <state-error wx:elif="{{loadError}}" bind:retry="load" />

  <state-empty
    wx:elif="{{!loading && items.length === 0}}"
    icon=""
    title="{{onlyDue ? '暂无待复习单词' : '词汇本还是空的'}}"
    desc="{{onlyDue ? '你已经复习完啦' : '在上方输入框添加你想记住的单词'}}"
  />

  <view wx:elif="{{activeItem}}" class="review-card">
    <view class="tag-row">
      <text class="chip chip-ink">{{activeItem.level || 'B1'}}</text>
      <text class="chip chip-ink">{{activeItem.category || '词汇'}}</text>
      <view class="memory-bars">
        <view class="bar active"></view>
        <view class="bar active"></view>
        <view class="bar active"></view>
        <view class="bar"></view>
        <view class="bar"></view>
      </view>
    </view>

    <view class="word-block">
      <text class="word-text">{{activeItem.word}}</text>
      <view class="phonetic-row">
        <text class="phonetic">{{activeItem.phonetic || '/ pronunciation /'}}</text>
        <button class="sound-btn"> </button>
      </view>
    </view>

    <view wx:if="{{revealed}}" class="answer-block">
      <view>
        <text class="part-chip">释义</text>
        <text class="meaning-text">{{activeItem.meaning || '暂无释义'}}</text>
      </view>
      <view class="example-box">
        <text class="example-label">例句</text>
        <text class="example-text">{{activeItem.example || 'Add this word to a scene and review it in context.'}}</text>
      </view>
    </view>

    <view wx:else class="recall-prompt">
      <text>你还记得这个词的意思吗？</text>
      <button class="ghost-btn" bindtap="revealAnswer">
        <view class="mini-icon mini-icon-eye"></view>
        <text>查看释义</text>
      </button>
    </view>

    <view class="card-actions">
      <button class="mini-action mini-star">
        <view class="mini-icon mini-icon-star"></view>
        <text>收藏</text>
      </button>
      <button class="mini-action mini-mic">
        <view class="mini-icon mini-icon-mic"></view>
        <text>跟读</text>
      </button>
    </view>
  </view>

  <view class="grade-dock" wx:if="{{activeItem}}">
    <button wx:if="{{!revealed}}" class="show-answer-btn" bindtap="revealAnswer">显示答案</button>
    <block wx:else>
      <button class="grade-btn coral" bindtap="onRate" data-word="{{activeItem.word}}" data-rating="again">
        <text>忘了</text><text class="sub">{{'<'}} 1m</text>
      </button>
      <button class="grade-btn lemon" bindtap="onRate" data-word="{{activeItem.word}}" data-rating="hard">
        <text>模糊</text><text class="sub">10m</text>
      </button>
      <button class="grade-btn mint" bindtap="onRate" data-word="{{activeItem.word}}" data-rating="good">
        <text>记得</text><text class="sub">1d</text>
      </button>
      <button class="grade-btn indigo" bindtap="onRate" data-word="{{activeItem.word}}" data-rating="easy">
        <text>简单</text><text class="sub">4d</text>
      </button>
    </block>
  </view>
</view>
