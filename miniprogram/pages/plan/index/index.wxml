<view class="plan-page">
  <skeleton type="list" rows="{{3}}" wx:if="{{loading}}" />

  <view wx:elif="{{noPlan}}" class="no-plan-state">
    <view class="empty-mark"></view>
    <text class="no-plan-title">还没有学习计划</text>
    <text class="no-plan-desc">完成水平测评后，系统将为你生成个性化学习计划</text>
    <button class="no-plan-btn" bindtap="goAssessment">开始水平测评</button>
  </view>

  <view wx:else class="plan-screen">
    <view class="plan-hero">
      <view class="hero-deco deco-large"></view>
      <view class="hero-deco deco-small"></view>

      <view class="hero-appbar">
        <view class="nav-icon back-icon" bindtap="goBack"></view>
        <text>学习计划</text>
        <view class="nav-icon settings-icon" bindtap="adjustPlan"></view>
      </view>

      <view class="hero-content">
        <text class="plan-kicker">{{planTitle}}</text>
        <text class="plan-headline">{{planSubtitle}}</text>

        <view class="progress-row">
          <text class="big-percent t-mono">{{plan.overall_progress}}%</text>
          <view class="progress-main">
            <view class="progress-meta">
              <text>已完成 {{completedDays}} 天</text>
              <text>剩余 {{remainingDays}} 天</text>
            </view>
            <view class="hero-progress">
              <view class="hero-progress-fill" style="width: {{plan.overall_progress}}%;"></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="plan-scroll">
      <view class="week-card">
        <view class="section-head">
          <text class="section-title">本周 · 第 {{currentWeek}} 周</text>
          <text class="section-meta">{{weekDoneCount}} / 7 天</text>
        </view>
        <view class="week-strip">
          <view wx:for="{{weekDays}}" wx:key="day" class="week-day {{item.state}}">
            <text class="week-label">{{item.label}}</text>
            <text class="week-num">{{item.day}}</text>
            <view class="week-state-dot"></view>
          </view>
        </view>
      </view>

      <view class="today-section">
        <view class="section-head">
          <view class="title-with-meta">
            <text class="section-title">今日任务</text>
            <text class="inline-meta">· {{todayDateLabel}}</text>
          </view>
          <text class="accent-meta">{{completedTaskCount}}/{{todayTasks.length}} · {{todayMinutesDone}} 分钟</text>
        </view>

        <view class="task-list" wx:if="{{taskViews.length > 0}}">
          <view
            wx:for="{{taskViews}}"
            wx:key="dialogue_id"
            class="plan-task {{item.statusClass}}"
            bindtap="startDialogue"
            data-dialogue-id="{{item.dialogue_id}}"
          >
            <view class="task-icon tone-{{item.tone}} icon-{{item.icon}}"></view>
            <view class="task-copy">
              <view class="task-tag-row">
                <text class="task-tag tone-{{item.tone}}">{{item.tag}}</text>
                <text class="task-extra" wx:if="{{item.extra}}">{{item.extra}}</text>
              </view>
              <text class="task-title">{{item.title}}</text>
              <text class="task-meta">{{item.meta}}</text>
              <view class="task-progress" wx:if="{{item.showProgress}}">
                <view class="task-progress-fill" style="width: {{item.progressPercent}}%;"></view>
              </view>
            </view>
            <view class="task-tail {{item.tailClass}}"></view>
          </view>
        </view>

        <view class="empty-tasks" wx:else>
          <text>今日任务已完成</text>
        </view>
      </view>

      <view class="path-section">
        <view class="section-head">
          <text class="section-title">完整路径</text>
          <view class="section-link" bindtap="adjustPlan">
            <text>调整目标</text>
            <view class="link-chevron"></view>
          </view>
        </view>

        <view class="path-list">
          <view
            wx:for="{{pathWeeks}}"
            wx:key="week"
            class="path-item {{item.status}}"
            bindtap="viewScenario"
            data-scenario-id="{{item.scenario_id}}"
          >
            <view class="week-badge">
              <text>WEEK</text>
              <text>{{item.week}}</text>
            </view>
            <view class="path-copy">
              <view class="path-title-row">
                <text class="path-title">{{item.title}}</text>
                <text class="path-chip {{item.chipClass}}" wx:if="{{item.showChip}}">{{item.chipText}}</text>
                <view class="path-chevron" wx:if="{{item.showChevron}}"></view>
              </view>
              <text class="path-meta">{{item.range}} · {{item.summary}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="goal-card">
        <view class="goal-icon"></view>
        <view class="goal-copy">
          <text class="goal-title">每日目标 · {{plan.daily_minutes}} 分钟</text>
          <text class="goal-text">今日已学 {{todayMinutesDone}} 分钟，再坚持 {{todayMinutesRemaining}} 分钟保持连击！</text>
        </view>
        <view class="goal-progress">
          <view class="goal-progress-fill" style="width: {{dailyGoalPercent}}%;"></view>
        </view>
      </view>

      <view class="actions">
        <button class="primary-action" bindtap="continueStudy" disabled="{{continueDisabled}}">
          {{continueLabel}}
        </button>
        <button class="secondary-action" bindtap="adjustPlan">调整计划</button>
      </view>

      <view class="bottom-spacer"></view>
    </view>
  </view>
</view>
