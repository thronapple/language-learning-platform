.welcome-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.welcome-content {
  margin-bottom: 80rpx;
}

.welcome-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.action-section {
  width: 100%;
  max-width: 400rpx;
}

.start-btn {
  width: 100%;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(22, 119, 255, 0.3);
  transition: all 0.3s ease;
}

.start-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 24rpx rgba(22, 119, 255, 0.4);
}

.features-section {
  display: flex;
  justify-content: space-around;
  width: 100%;
  max-width: 500rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

