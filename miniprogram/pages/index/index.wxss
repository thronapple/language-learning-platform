.page {
  min-height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 0 calc(60rpx + 100rpx + env(safe-area-inset-bottom));
}

/* 头部渐变区 */
.hero {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.hero-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.hero-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

/* 功能亮点 */
.features {
  display: flex;
  justify-content: space-around;
  width: 100%;
  padding: 40rpx 32rpx 16rpx;
  gap: 20rpx;
  box-sizing: border-box;
}

.feature-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.12);
  transition: all 0.2s ease;
}

.feature-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.08);
}

.feature-icon {
  font-size: 48rpx;
}

.feature-label {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}

/* 操作区 */
.action-area {
  width: 100%;
  padding: 32rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  padding: 28rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-primary::after {
  border: none;
}

.btn-primary[loading] {
  opacity: 0.8;
}

.hint-text {
  font-size: 24rpx;
  color: #999;
}
