<view class="container welcome-page">
  <view class="welcome-content">
    <view class="welcome-icon">📚</view>
    <view class="title-large mt-lg">欢迎开始每日 5 分钟学习</view>
    <view class="body-medium mt-sm">每天坚持一点点，语言能力大提升</view>
  </view>
  
  <view class="action-section">
    <button class="start-btn" bindtap="goStudy" loading="{{loading}}">
      {{loading ? '准备中...' : '开始学习'}}
    </button>
    <view class="caption mt-md">首次进入会拉取内容列表</view>
  </view>
  
  <view class="features-section mt-xl">
    <view class="feature-item">
      <view class="feature-icon">🎧</view>
      <view class="feature-text">音频跟读</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">📝</view>
      <view class="feature-text">单词记忆</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">⚡</view>
      <view class="feature-text">快速进步</view>
    </view>
  </view>
</view>

