<view class="page">
  <!-- 头部渐变区 -->
  <view class="hero">
    <view class="hero-icon">📚</view>
    <view class="hero-title">每日 5 分钟</view>
    <view class="hero-sub">坚持一点点，语言能力大提升</view>
  </view>

  <!-- 功能亮点 -->
  <view class="features">
    <view class="feature-card" bindtap="goStudy">
      <text class="feature-icon">🎧</text>
      <text class="feature-label">跟读练习</text>
    </view>
    <view class="feature-card" bindtap="goAssessment">
      <text class="feature-icon">📝</text>
      <text class="feature-label">水平评估</text>
    </view>
    <view class="feature-card" bindtap="goPlan">
      <text class="feature-icon">📈</text>
      <text class="feature-label">学习计划</text>
    </view>
  </view>

  <!-- 操作区 -->
  <view class="action-area">
    <button class="btn-primary" bindtap="goStudy" loading="{{loading}}">
      开始学习
    </button>
    <view class="hint-text">首次使用将进行水平评估</view>
  </view>
</view>
