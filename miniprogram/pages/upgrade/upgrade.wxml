<view class="page">
  <view class="header">
    <view class="hero-deco deco-large"></view>
    <view class="hero-deco deco-small"></view>
    <view class="header-icon premium-mark"></view>
    <view class="header-title">升级 Pro</view>
    <view class="header-sub">解锁全部功能，提升学习效率</view>
  </view>

  <view class="content">
    <!-- 权益列表 -->
    <view class="benefits-card">
      <view class="benefits-title">Pro 会员权益</view>
      <view class="benefit-item">
        <view class="benefit-icon no-ad-icon"></view>
        <text class="benefit-text">去除所有广告</text>
      </view>
      <view class="benefit-item">
        <view class="benefit-icon book-icon"></view>
        <text class="benefit-text">导入配额翻倍</text>
      </view>
      <view class="benefit-item">
        <view class="benefit-icon report-icon"></view>
        <text class="benefit-text">每周学习报告</text>
      </view>
      <view class="benefit-item">
        <view class="benefit-icon ai-icon"></view>
        <text class="benefit-text">AI 口语评分（即将推出）</text>
      </view>
    </view>

    <!-- 定价选择 -->
    <view class="pricing-section">
      <view class="section-title">选择方案</view>
      <view class="pricing-grid">
        <view
          class="price-card {{plan === 'monthly' && price === '9.9' ? 'selected' : ''}}"
          bindtap="choose"
          data-plan="monthly"
          data-price="9.9"
        >
          <view class="price-period">月付</view>
          <view class="price-amount">¥9.9</view>
          <view class="price-unit">/月</view>
        </view>
        <view
          class="price-card {{plan === 'monthly' && price === '14.9' ? 'selected' : ''}}"
          bindtap="choose"
          data-plan="monthly"
          data-price="14.9"
        >
          <view class="price-period">月付 Plus</view>
          <view class="price-amount">¥14.9</view>
          <view class="price-unit">/月</view>
        </view>
        <view
          class="price-card {{plan === 'yearly' ? 'selected' : ''}}"
          bindtap="choose"
          data-plan="yearly"
          data-price="69"
        >
          <view class="price-period">年付</view>
          <view class="price-amount">¥69</view>
          <view class="price-unit">/年 省40%</view>
        </view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="contact-card">
      <view class="contact-label">留下联系方式，正式上线后通知你</view>
      <input
        class="contact-input"
        placeholder="微信号 / 手机号 / 邮箱"
        value="{{contact}}"
        bindinput="onInput"
      />
    </view>

    <button
      class="submit-btn"
      bindtap="submit"
      disabled="{{!contact || submitting}}"
      loading="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交愿望单'}}
    </button>

    <view class="footer-note">功能预告，正式上线后以实际为准</view>
  </view>
</view>
