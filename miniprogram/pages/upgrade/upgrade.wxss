.page {
  min-height: 100vh;
  background: #f5f7fa;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 48rpx 40rpx;
  text-align: center;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.content {
  padding: 32rpx;
}

/* 权益列表 */
.benefits-card {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  margin-bottom: 24rpx;
}

.benefits-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.benefit-icon {
  font-size: 32rpx;
}

.benefit-text {
  font-size: 28rpx;
  color: #555;
}

/* 定价选择 */
.pricing-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.pricing-grid {
  display: flex;
  gap: 16rpx;
}

.price-card {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.price-card.selected {
  border-color: #667eea;
  background: #f5f3ff;
}

.price-card:active {
  transform: scale(0.97);
}

.price-period {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.price-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
}

/* 联系方式 */
.contact-card {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  margin-bottom: 24rpx;
}

.contact-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.contact-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 46rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.footer-note {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 24rpx;
}
