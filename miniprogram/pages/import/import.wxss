.page {
  min-height: 100vh;
  background: var(--ink-50);
  color: var(--ink-900);
}

.header {
  position: relative;
  overflow: hidden;
  padding: 48rpx 40rpx 56rpx;
  background: var(--gradient-primary);
  color: white;
}

.hero-deco {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.deco-large {
  right: -80rpx;
  top: -80rpx;
  width: 300rpx;
  height: 300rpx;
}

.deco-small {
  right: 96rpx;
  bottom: -60rpx;
  width: 140rpx;
  height: 140rpx;
}

.header-kicker {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  opacity: 0.88;
}

.header-title {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 900;
}

.header-sub {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  font-weight: 700;
}

.content {
  padding: 32rpx;
}

.input-card {
  background: var(--paper);
  border: 2rpx solid var(--ink-100);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.import-textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ink-900);
  font-weight: 700;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--ink-400);
  font-weight: 800;
  margin-top: 8rpx;
}

.import-btn {
  width: 100%;
  height: 104rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  color: #fff;
  background: var(--brand-500);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 8rpx 0 var(--brand-700), var(--shadow-sm);
  margin-bottom: 40rpx;
}

.import-btn::after {
  border: none;
}

.import-btn[disabled] {
  opacity: 1;
  background: var(--ink-200);
  color: var(--ink-500);
  box-shadow: 0 8rpx 0 var(--ink-300), var(--shadow-xs);
}

.tips {
  background: var(--paper);
  border: 2rpx solid var(--ink-100);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.tips-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--ink-900);
  margin-bottom: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  font-size: 26rpx;
  color: var(--ink-700);
  line-height: 1.5;
  font-weight: 800;
  padding: 16rpx 0;
}

.tip-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-sm);
  background: var(--brand-100);
  position: relative;
  flex-shrink: 0;
}

.tip-icon::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--brand-700);
  -webkit-mask: center / contain no-repeat;
          mask: center / contain no-repeat;
}

