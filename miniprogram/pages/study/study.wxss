/* 音频播放器区域 */
.player {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.audio-controls {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  align-items: center;
}

.control-btn {
  background: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  min-width: 100rpx;
}

.control-btn.secondary {
  background: #ffffff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

/* 工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.05);
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hint {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.timer-display {
  color: var(--primary-color);
  font-size: 24rpx;
  font-weight: 600;
}

/* 句子列表区域 */
.sentences {
  height: 55vh;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.sentence {
  padding: 20rpx 16rpx;
  margin: 8rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.sentence.active {
  background: linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%);
  border: 2rpx solid var(--primary-color);
  transform: scale(1.02);
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.2);
}

/* 控制按钮区域 */
.controls {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin: 24rpx 0;
}

.nav-btn {
  flex: 1;
  background: #ffffff;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  font-size: 26rpx;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.controls .nav-btn.primary {
  background: #1677ff !important;
  color: #ffffff !important;
  border-color: #1677ff !important;
}

.controls .nav-btn.finish {
  background: #52c41a !important;
  color: #ffffff !important;
  border-color: #52c41a !important;
}

/* 确保所有状态下的颜色都正确 */
.nav-btn.primary,
.nav-btn.primary:hover,
.nav-btn.primary:active,
.nav-btn.primary:focus {
  background: #1677ff !important;
  color: #ffffff !important;
}

.nav-btn.finish,
.nav-btn.finish:hover,
.nav-btn.finish:active,
.nav-btn.finish:focus {
  background: #52c41a !important;
  color: #ffffff !important;
}

/* 页脚提示 */
.footer {
  text-align: center;
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 16rpx 0;
}
