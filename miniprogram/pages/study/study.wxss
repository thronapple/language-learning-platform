.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 60rpx;
}

/* 顶部信息栏 — 全宽，内侧有 padding */
.top-bar {
  background: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.sentence-counter {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.counter-current {
  font-size: 44rpx;
  font-weight: 700;
  color: #667eea;
}

.counter-sep {
  font-size: 28rpx;
  color: #ccc;
  margin: 0 4rpx;
}

.counter-total {
  font-size: 28rpx;
  color: #999;
}

.timer-badge {
  background: #f0f0ff;
  color: #667eea;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

/* 音频卡片 */
.audio-card {
  background: white;
  margin: 24rpx 32rpx 0;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.1);
}

.audio-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.btn-play {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-play.playing {
  background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
}

.btn-play-label {
  font-size: 28rpx;
}

.btn-speed {
  width: 120rpx;
  height: 88rpx;
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auto-next-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.auto-label {
  font-size: 26rpx;
  color: #666;
}

/* 句子列表 — 用父容器控制边距，避免 scroll-view 右侧 margin 失效 */
.sentences-wrap {
  margin: 24rpx 32rpx 0;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.1);
  overflow: hidden;
}

.sentences {
  min-height: 200rpx;
  max-height: 50vh;
  padding: 8rpx 0;
}

.sentence-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  margin: 8rpx 12rpx;
  transition: all 0.3s;
}

.sentence-item.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border: 2rpx solid #667eea;
}

.sentence-index {
  width: 44rpx;
  height: 44rpx;
  background: #eee;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  line-height: 44rpx;
  text-align: center;
}

.sentence-item.active .sentence-index {
  background: #667eea;
  color: white;
}

.sentence-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.sentence-item.active .sentence-text {
  font-weight: 500;
}

/* 导航按钮 */
.nav-area {
  display: flex;
  gap: 24rpx;
  margin: 24rpx 32rpx 0;
}

.nav-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-prev {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.btn-prev[disabled] {
  background: #f5f5f5;
  color: #ccc;
  border-color: #eee;
}

.btn-next {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-next[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 完成按钮 */
.finish-area {
  margin: 20rpx 32rpx 0;
}

.btn-finish {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  border: none;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.3);
}
