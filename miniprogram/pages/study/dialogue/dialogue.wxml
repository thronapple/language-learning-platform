<view class="dialogue-page">
  <skeleton type="article" wx:if="{{loading}}" />

  <view wx:else class="dialogue-screen">
    <view class="dialogue-hero">
      <view class="hero-deco"></view>
      <view class="hero-bar">
        <view class="nav-icon back-icon" bindtap="goBack"></view>
        <text class="scenario-label">SCENARIO · {{dialogue.level}}</text>
        <view class="nav-icon settings-icon"></view>
      </view>
      <view class="scenario-copy">
        <view class="scenario-type">
          <view class="coffee-icon"></view>
          <text>{{dialogue.title_zh}}</text>
        </view>
        <text class="scenario-title">{{dialogue.title_en}}</text>
        <view class="scenario-meta">
          <text>· {{dialogue.sentences.length}} 轮对话</text>
          <text wx:if="{{newWordsCount > 0}}">· {{newWordsCount}} 个新词</text>
          <text>· 进度 {{currentIndex + 1}}/{{dialogue.sentences.length}}</text>
        </view>
        <view class="hero-progress">
          <view class="hero-progress-fill" style="width: {{progressPercent}}%;"></view>
        </view>
      </view>
    </view>

    <scroll-view
      class="conversation-scroll"
      scroll-y
      bindtouchstart="onTouchStart"
      bindtouchend="onTouchEnd"
    >
      <view
        wx:for="{{displaySentences}}"
        wx:key="order"
        class="turn {{item.isUser ? 'user' : 'bot'}} {{item.isCurrent ? 'current' : ''}}"
      >
        <view wx:if="{{!item.isUser}}" class="avatar bot">{{item.avatarText}}</view>
        <view class="bubble-wrap">
          <text class="speaker-name">{{item.isUser ? 'You' : item.speaker}}</text>
          <view class="bubble">
            <text class="english">{{item.text_en}}</text>
            <text class="chinese">{{item.text_zh}}</text>
            <view class="bubble-actions" wx:if="{{!item.isUser}}">
              <button class="play-btn" bindtap="toggleAudio" data-index="{{index}}">
                <view class="play-glyph {{isPlaying && item.isCurrent ? 'pause' : 'play'}}"></view>
                <text>{{isPlaying && item.isCurrent ? '暂停' : '0:03'}}</text>
              </button>
              <button class="speed-btn" bindtap="toggleSpeed">{{playbackRate}}×</button>
            </view>
            <view class="score-pill" wx:if="{{item.score}}">
              <text class="score-value">★ {{item.score}}/100</text>
              <text class="score-label">{{item.scoreLabel}}</text>
            </view>
          </view>
        </view>
        <view wx:if="{{item.isUser}}" class="avatar user">YOU</view>
      </view>

      <view class="record-prompt">
        <text class="prompt-label">{{evaluating ? '评测中' : isRecording ? '录音中' : '轮到你了 · 长按录音'}}</text>
        <text class="prompt-text" wx:if="{{currentPromptZh}}">
          请用英文回应：{{currentPromptZh}}
        </text>
      </view>
    </scroll-view>

    <view class="score-section" wx:if="{{showScore && scoreInfo}}">
      <view class="score-bar" style="border-color: {{scoreInfo.color}};">
        <text class="score-number" style="color: {{scoreInfo.color}};">{{scoreInfo.score}}</text>
        <view class="score-copy">
          <text class="score-level" style="color: {{scoreInfo.color}};">{{scoreInfo.level}}</text>
          <text class="score-reco" wx:if="{{recognizedText}}">{{recognizedText}}</text>
        </view>
      </view>
    </view>

    <view class="mic-dock">
      <button class="dock-btn refresh-btn" bindtap="reRecord">
        <text class="refresh-glyph">↻</text>
      </button>
      <button
        class="mic-btn {{isRecording ? 'recording' : ''}}"
        bindtouchstart="startRecording"
        bindtouchend="stopRecording"
      >
        <view class="mic-icon"></view>
      </button>
      <button class="dock-btn" bindtap="nextSentence">
        <view class="next-icon"></view>
      </button>
    </view>

    <view class="completion-modal" wx:if="{{showCompletion}}">
      <view class="modal-content">
        <view class="modal-mark"></view>
        <text class="modal-title">完成对话</text>
        <text class="modal-desc">你已完成《{{dialogue.title_zh}}》的学习</text>

        <view class="completion-stats">
          <view class="stat-item">
            <text class="stat-value">{{dialogue.sentences.length}}</text>
            <text class="stat-label">句子</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{playCount}}</text>
            <text class="stat-label">播放</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{recordCount}}</text>
            <text class="stat-label">跟读</text>
          </view>
        </view>

        <view class="modal-actions">
          <button class="modal-btn primary" bindtap="finishDialogue">完成学习</button>
          <button class="modal-btn secondary" bindtap="reviewDialogue">再次复习</button>
        </view>
      </view>
    </view>
  </view>
</view>
