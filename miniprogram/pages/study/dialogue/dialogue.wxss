.dialogue-page {
  min-height: 100vh;
  background: #f5f7fa;
}

.fade-in {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部信息 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx 40rpx;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dialogue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.dialogue-title {
  font-size: 34rpx;
  font-weight: 700;
}

.dialogue-subtitle {
  font-size: 24rpx;
  opacity: 0.85;
}

.progress-info {
  background: rgba(255, 255, 255, 0.25);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.current-sentence {
  font-size: 24rpx;
  font-weight: 600;
}

/* 进度条 */
.progress-container {
  padding: 0 40rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.progress-bar {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: white;
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* 句子容器 — flex: 1 填充中间空间，居中卡片 */
.sentence-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
}

.sentence-item {
  width: 100%;
  background: white;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 说话人标签 */
.speaker-tag {
  display: inline-block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 文本区域 */
.text-section {
  margin-bottom: 20rpx;
}

.text-en {
  display: block;
  font-size: 36rpx;
  line-height: 1.7;
  color: #333;
  font-weight: 500;
}

.text-zh {
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: #666;
}

/* 音标 */
.phonetic-section {
  background: #f8f9ff;
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.phonetic-text {
  font-size: 26rpx;
  color: #667eea;
  font-family: 'Times New Roman', serif;
}

/* 关键词 */
.keywords-section {
  padding-top: 20rpx;
  border-top: 2rpx dashed #e0e0e0;
}

.keywords-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: #fff3e0;
  color: #ffa726;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 底部操作面板 — 不再 fixed，跟随 flex 布局 */
.bottom-panel {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 辅助功能 */
.assist-functions {
  display: flex;
  justify-content: space-around;
  gap: 12rpx;
}

.function-btn {
  flex: 1;
  background: #f5f7fa;
  border-radius: 14rpx;
  padding: 14rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.fn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #666;
}

/* 跟读评分 */
.score-section {
  animation: fadeIn 0.3s ease;
}

.score-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  border-left: 6rpx solid;
}

.score-left {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.score-number {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1;
}

.score-unit {
  font-size: 22rpx;
  color: #999;
}

.score-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.score-level {
  font-size: 28rpx;
  font-weight: 600;
}

.score-reco {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 录音按钮 */
.record-section {
  display: flex;
  justify-content: center;
}

.record-btn {
  width: 100%;
  height: 84rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
  line-height: 1;
}

.record-btn.recording {
  background: linear-gradient(135deg, #ee5a6f 0%, #f29263 100%);
  animation: recordPulse 1s ease infinite;
}

@keyframes recordPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}

.record-btn .icon {
  font-size: 32rpx;
}

.record-btn .record-text {
  font-size: 30rpx;
}

/* 导航按钮 */
.navigation {
  display: flex;
  gap: 16rpx;
}

.nav-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 42rpx;
  padding: 0;
}

.nav-btn.prev {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.nav-btn.prev[disabled] {
  background: #f0f2f5;
  color: #999;
  border-color: #e0e0e0;
}

.nav-btn.next {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

/* 完成弹窗 */
.completion-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
  margin: 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 36rpx;
  text-align: center;
}

.completion-stats {
  width: 100%;
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-top: 2rpx dashed #e0e0e0;
  border-bottom: 2rpx dashed #e0e0e0;
  margin-bottom: 36rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.modal-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 42rpx;
  padding: 0;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.modal-btn.secondary {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}
