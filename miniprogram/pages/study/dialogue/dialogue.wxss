.dialogue-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 300rpx;
}

/* 顶部信息 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.dialogue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dialogue-title {
  font-size: 36rpx;
  font-weight: 700;
}

.dialogue-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.progress-info {
  background: rgba(255, 255, 255, 0.3);
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.current-sentence {
  font-size: 24rpx;
  font-weight: 600;
}

/* 进度条 */
.progress-container {
  padding: 0 40rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: white;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 句子容器 */
.sentence-container {
  padding: 40rpx;
  min-height: 500rpx;
}

.sentence-item {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 说话人标签 */
.speaker-tag {
  display: inline-block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

/* 文本区域 */
.text-section {
  margin-bottom: 24rpx;
}

.text-en {
  display: block;
  font-size: 36rpx;
  line-height: 1.8;
  color: #333;
  font-weight: 500;
}

.text-zh {
  display: block;
  font-size: 30rpx;
  line-height: 1.8;
  color: #666;
}

/* 音标 */
.phonetic-section {
  background: #f8f9ff;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.phonetic-text {
  font-size: 26rpx;
  color: #667eea;
  font-family: 'Times New Roman', serif;
}

/* 关键词 */
.keywords-section {
  padding-top: 24rpx;
  border-top: 2rpx dashed #e0e0e0;
}

.keywords-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: #fff3e0;
  color: #ffa726;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 音频控制 */
.audio-control {
  position: fixed;
  bottom: 180rpx;
  left: 40rpx;
  right: 40rpx;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
}

.audio-player {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.play-button {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.play-button .icon {
  font-size: 36rpx;
  color: white;
}

.audio-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.audio-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.play-count {
  font-size: 24rpx;
  color: #999;
}

.speed-control {
  width: 80rpx;
  height: 80rpx;
  background: #f0f2f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.speed-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
}

/* 录音按钮 */
.record-section {
  display: flex;
  justify-content: center;
}

.record-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: white;
  font-size: 30rpx;
  font-weight: 600;
}

.record-btn.recording {
  background: linear-gradient(135deg, #ee5a6f 0%, #f29263 100%);
  animation: pulse 1s ease infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.record-btn .icon {
  font-size: 32rpx;
}

/* 辅助功能 */
.assist-functions {
  position: fixed;
  bottom: 300rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.function-btn {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.function-btn .icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #666;
}

/* 导航按钮 */
.navigation {
  position: fixed;
  bottom: 30rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  gap: 20rpx;
}

.nav-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.nav-btn.prev {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.nav-btn.prev[disabled] {
  background: #f0f2f5;
  color: #999;
  border-color: #e0e0e0;
}

.nav-btn.next {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

/* 完成弹窗 */
.completion-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  margin: 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  text-align: center;
}

.completion-stats {
  width: 100%;
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  border-top: 2rpx dashed #e0e0e0;
  border-bottom: 2rpx dashed #e0e0e0;
  margin-bottom: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.modal-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.modal-btn.secondary {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}
