<view class="assessment-test">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-info">
      <text class="current">{{currentQuestion}}/{{totalQuestions}}</text>
      <text class="timer" wx:if="{{timeLeft > 0}}">剩余 {{timeLeft}}秒</text>
    </view>
    <progress percent="{{progress}}" stroke-width="6" activeColor="#667eea"/>
  </view>

  <!-- 题目内容 -->
  <view class="question-content" wx:if="{{question}}">
    <!-- 听力题: 音频播放器 -->
    <view class="audio-player" wx:if="{{question.type === 'listening'}}">
      <view class="audio-icon" bindtap="toggleAudio">
        <text class="icon">{{isPlaying ? '⏸' : '▶️'}}</text>
      </view>
      <view class="audio-info">
        <text class="audio-text">点击播放音频</text>
        <text class="listen-count">已播放 {{listenCount}} 次</text>
      </view>
    </view>

    <!-- 阅读题: 文本内容 -->
    <view class="passage-box" wx:if="{{question.type === 'reading'}}">
      <scroll-view scroll-y class="passage-scroll">
        <text class="passage-text">{{question.content.passage}}</text>
      </scroll-view>
    </view>

    <!-- 问题 -->
    <view class="question-box">
      <text class="question-label">题目:</text>
      <text class="question-text">{{question.content.question}}</text>
      <text class="question-zh">{{question.content.question_zh}}</text>
    </view>

    <!-- 选项 -->
    <view class="options">
      <view
        wx:for="{{question.content.options}}"
        wx:key="index"
        class="option-item {{selectedIndex === index ? 'selected' : ''}}"
        bindtap="selectOption"
        data-index="{{index}}"
      >
        <view class="option-radio">
          <text wx:if="{{selectedIndex === index}}">●</text>
        </view>
        <text class="option-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button
      class="next-btn"
      type="primary"
      bindtap="nextQuestion"
      disabled="{{selectedIndex === null}}"
    >
      {{isLastQuestion ? '完成评估' : '下一题'}}
    </button>
  </view>

  <!-- 加载状态 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-box">
      <text class="loading-text">正在加载...</text>
    </view>
  </view>
</view>
