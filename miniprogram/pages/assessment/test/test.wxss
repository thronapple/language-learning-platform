.assessment-test {
  min-height: 100vh;
  background: var(--ink-50);
  color: var(--ink-900);
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.top-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  /* navigationStyle: custom 后需自行让出系统状态栏 + 胶囊高度 */
  padding: calc(env(safe-area-inset-top) + 96rpx) 32rpx 0;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--paper);
  border: 2rpx solid var(--ink-200);
  position: relative;
}

.back-btn::before {
  content: '';
  position: absolute;
  left: 28rpx;
  top: 24rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid var(--ink-700);
  border-bottom: 4rpx solid var(--ink-700);
  transform: rotate(45deg);
}

.progress-wrap {
  flex: 1;
}

.progress-track {
  height: 12rpx;
  border-radius: var(--radius-full);
  background: var(--ink-200);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--indigo-500);
  border-radius: var(--radius-full);
}

.question-count {
  min-width: 82rpx;
  color: var(--indigo-600);
  font-size: 26rpx;
  font-family: var(--font-mono);
  font-weight: 900;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx 0;
}

/* .chip / .chip-indigo / .chip-ink 来自 components.wxss，无需本地重写 */

.timer {
  margin-left: auto;
  color: var(--ink-500);
  font-size: 22rpx;
  font-weight: 900;
  font-family: var(--font-mono);
}

.test-body {
  padding: 40rpx;
}

.audio-card,
.passage-card {
  margin-bottom: 32rpx;
  padding: 32rpx;
  border-radius: var(--radius-lg);
  background: var(--paper);
  border: 2rpx solid var(--ink-100);
  box-shadow: var(--shadow-sm);
}

/* 阅读卡：左侧 indigo 色带 + 小标题，呼应整页的指示色 */
.passage-card {
  position: relative;
  padding-left: 36rpx;
  background: var(--ink-50);
  border: 0;
  box-shadow: none;
}

.passage-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 8rpx;
  border-radius: 8rpx;
  background: var(--indigo-300, var(--indigo-200));
}

.passage-label {
  display: block;
  margin-bottom: 16rpx;
  color: var(--indigo-600);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.audio-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.audio-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--indigo-500);
  position: relative;
  box-shadow: var(--shadow-indigo);
}

.audio-icon::before {
  content: '';
  position: absolute;
  left: 34rpx;
  top: 27rpx;
  width: 0;
  height: 0;
  border-top: 17rpx solid transparent;
  border-bottom: 17rpx solid transparent;
  border-left: 24rpx solid white;
}

.audio-icon.playing::before {
  left: 29rpx;
  top: 27rpx;
  width: 8rpx;
  height: 34rpx;
  border: 0;
  background: white;
  box-shadow: 18rpx 0 0 white;
}

.audio-title,
.audio-meta {
  display: block;
}

.audio-title {
  font-size: 30rpx;
  font-weight: 900;
}

.audio-meta {
  margin-top: 8rpx;
  color: var(--ink-500);
  font-size: 24rpx;
  font-weight: 700;
}

.passage-scroll {
  max-height: 360rpx;
  color: var(--ink-800);
  font-size: 30rpx;
  line-height: 1.7;
}

.prompt-label {
  display: block;
  color: var(--ink-500);
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.question-title {
  display: block;
  color: var(--ink-900);
  font-size: 38rpx;
  line-height: 1.5;
  font-weight: 900;
}

.question-zh {
  display: block;
  margin-top: 12rpx;
  color: var(--ink-600);
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
}

.options {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-lg);
  background: var(--paper);
  border: 4rpx solid var(--ink-200);
  box-sizing: border-box;
}

.option-card.selected {
  background: var(--indigo-50);
  border-color: var(--indigo-500);
  box-shadow: 0 8rpx 0 var(--indigo-200);
}

.option-letter {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--ink-100);
  color: var(--ink-600);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.option-card.selected .option-letter {
  background: var(--indigo-500);
  color: white;
}

.option-text {
  flex: 1;
  color: var(--ink-900);
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 800;
}

.option-check {
  width: 32rpx;
  height: 18rpx;
  border-left: 6rpx solid var(--indigo-500);
  border-bottom: 6rpx solid var(--indigo-500);
  transform: rotate(-45deg);
}

.action-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx calc(36rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, var(--ink-50) 78%, rgba(251, 249, 245, 0));
  z-index: 20;
}

/* 答题反馈：与设计语言统一的 in-page banner，替代默认 wx.showToast */
.answer-feedback {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(220rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 900;
  color: white;
  box-shadow: var(--shadow-md);
  z-index: 25;
  animation: feedbackIn 220ms var(--ease-out);
}

.feedback-correct {
  background: var(--mint-500);
}

.feedback-wrong {
  background: var(--coral-500);
}

.feedback-glyph {
  font-size: 36rpx;
  font-weight: 900;
}

@keyframes feedbackIn {
  from { transform: translateY(24rpx); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.skip-btn,
.confirm-btn {
  height: 104rpx;
  line-height: 104rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 900;
}

.skip-btn {
  width: 124rpx;
  background: var(--paper);
  color: var(--ink-700);
  border: 2rpx solid var(--ink-200);
}

.confirm-btn {
  flex: 1;
  background: var(--indigo-500);
  color: white;
  box-shadow: 0 8rpx 0 var(--indigo-700), var(--shadow-sm);
}

/* WeChat <button> 自身在 disabled 时会再叠一层 opacity，需要显式压回 1 */
button.confirm-btn[disabled] {
  background: var(--paper);
  color: var(--ink-500);
  border: 3rpx solid var(--ink-300);
  box-shadow: 0 4rpx 0 var(--ink-200), var(--shadow-xs);
  opacity: 1;
}

button::after {
  border: none;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(28, 26, 23, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-box {
  padding: 56rpx 72rpx;
  border-radius: var(--radius-lg);
  background: white;
  color: var(--ink-800);
  font-size: 30rpx;
  font-weight: 900;
}

