/* 评估引导页 - 优化版 */

.assessment-intro {
  min-height: 100vh;
  background: var(--gradient-primary);
  padding: var(--space-12) var(--space-10);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  animation: fadeIn var(--duration-slow) var(--ease-out);
}

/* ========== 头部区域 ========== */
.header {
  text-align: center;
  color: var(--text-inverse);
  margin-bottom: var(--space-16);
  animation: slideInDown 0.6s var(--ease-out);
}

@keyframes slideInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto var(--space-10);
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.title {
  display: block;
  font-size: var(--font-3xl);
  font-weight: var(--font-bold);
  margin-bottom: var(--space-5);
  letter-spacing: 1rpx;
}

.subtitle {
  display: block;
  font-size: var(--font-base);
  opacity: 0.95;
  font-weight: var(--font-medium);
}

/* ========== 特性列表 ========== */
.features {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.feature-item {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all var(--duration-base) var(--ease-out);
  animation: slideInRight calc(var(--duration-base) + var(--index) * 100ms) var(--ease-out);
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.feature-item:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.98);
}

.feature-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-6);
  flex-shrink: 0;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

.icon-text {
  font-size: 48rpx;
  animation: rotate 3s linear infinite;
}

@keyframes rotate {
  0%, 90%, 100% {
    transform: rotate(0deg);
  }
  95% {
    transform: rotate(15deg);
  }
}

.feature-content {
  flex: 1;
  padding-top: var(--space-2);
}

.feature-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: var(--font-semibold);
  color: var(--text-inverse);
  margin-bottom: var(--space-3);
}

.feature-desc {
  display: block;
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.9);
  line-height: var(--leading-relaxed);
}

/* ========== 操作区域 ========== */
.actions {
  margin-top: var(--space-12);
  text-align: center;
  animation: slideInUp 0.8s var(--ease-out);
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.start-btn {
  width: 100%;
  height: 112rpx;
  line-height: 112rpx;
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  border-radius: var(--radius-full);
  background: var(--bg-primary);
  color: #667eea;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
  transition: all var(--duration-fast) var(--ease-out);
}

.start-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(103, 126, 234, 0.1),
    transparent
  );
  transition: left 0.5s ease;
}

.start-btn:active::before {
  left: 100%;
}

.start-btn:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
}

/* 按钮内文字 */
.start-btn::after {
  border: none;
}

.skip-text {
  display: inline-block;
  margin-top: var(--space-8);
  padding: var(--space-4) var(--space-6);
  font-size: var(--font-base);
  color: rgba(255, 255, 255, 0.8);
  border-radius: var(--radius-full);
  transition: all var(--duration-fast) var(--ease-out);
}

.skip-text:active {
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 1);
  transform: scale(0.95);
}

/* ========== 响应式优化 ========== */
@media (max-height: 1200rpx) {
  .header {
    margin-bottom: var(--space-10);
  }

  .icon {
    width: 120rpx;
    height: 120rpx;
  }

  .features {
    gap: var(--space-4);
  }

  .feature-item {
    padding: var(--space-6);
  }
}
