<view class="assessment-intro">
  <view class="appbar">
    <view class="close-btn" bindtap="skipAssessment"></view>
    <text class="step-label">STEP 1 OF 3</text>
    <view class="appbar-spacer"></view>
  </view>

  <view class="intro-scroll">
    <view class="hero-art">
      <view class="art-deco deco-left"></view>
      <view class="art-deco deco-right"></view>
      <view class="target-mark">
        <view class="target-ring"></view>
      </view>
      <text class="algorithm-chip">IRT 自适应算法</text>
    </view>

    <view class="headline">
      <text class="display-title">测一测\n你的英语水平</text>
      <text class="subtitle">约 15 题，5 分钟完成\n根据答题表现智能调整难度</text>
    </view>

    <view class="level-card">
      <text class="card-title">将定位到 CEFR 等级</text>
      <view class="level-bars">
        <view wx:for="{{levels}}" wx:key="*this" class="level-item item-{{index}}">
          <text>{{item}}</text>
          <view class="level-bar"></view>
        </view>
      </view>
      <text class="level-desc">覆盖词汇、语法、阅读、听力四个维度</text>
    </view>

    <view class="feature-list">
      <view class="feature-item">
        <view class="feature-icon sparkle"></view>
        <text>智能难度调整</text>
      </view>
      <view class="feature-item">
        <view class="feature-icon clock"></view>
        <text>随时可以暂停</text>
      </view>
      <view class="feature-item">
        <view class="feature-icon flag"></view>
        <text>生成个性化学习计划</text>
      </view>
    </view>

    <button class="start-btn" bindtap="startAssessment">开始测评</button>
    <view class="skip-line">已有账号？ <text bindtap="skipAssessment">跳过测评</text></view>
  </view>
</view>
