<view class="assessment-result">
  <view class="result-hero" wx:if="{{result}}">
    <view class="hero-deco"></view>
    <view class="result-appbar">
      <view class="close-btn" bindtap="closeResult"></view>
    </view>
    <view class="level-block">
      <text class="level-label">测评完成 · 你的水平是</text>
      <view class="level-row">
        <text class="level">{{result.overall_level}}</text>
        <text class="level-name">中级</text>
      </view>
      <text class="level-desc">能就熟悉的话题进行流畅交流</text>
    </view>
  </view>

  <view wx:if="{{result}}" class="result-scroll">
    <canvas canvas-id="radarCanvas" id="radarCanvas" class="radar-canvas-hidden"></canvas>

    <view class="card ability-card">
      <text class="card-title">能力分析</text>
      <view class="dimension-row" wx:for="{{dimensionList}}" wx:key="name" bindtap="onDimensionTap" data-name="{{item.name}}">
        <view class="dimension-head">
          <text>{{item.label}}</text>
          <text>{{item.accuracyPercent}}/100</text>
        </view>
        <view class="progress-track">
          <view class="progress-fill" style="width: {{item.accuracyPercent}}%; background: {{item.color}};"></view>
        </view>
      </view>
    </view>

    <view class="focus-card" wx:if="{{hasWeakAreas}}">
      <view class="focus-icon"></view>
      <view class="focus-copy">
        <text class="focus-title">推荐重点提升</text>
        <text class="focus-text">{{primaryWeakArea}} 较薄弱，建议每日 10 分钟针对练习</text>
      </view>
    </view>

    <view class="plan-section">
      <text class="section-title">为你定制的学习计划</text>
      <view class="plan-list">
        <view class="plan-item">
          <text class="plan-num">01</text>
          <view>
            <text class="plan-title">每日 8 分钟 SRS 复习</text>
            <text class="plan-meta">巩固 {{result.overall_level}} 核心词汇</text>
          </view>
        </view>
        <view class="plan-item">
          <text class="plan-num">02</text>
          <view>
            <text class="plan-title">每周 3 次场景对话</text>
            <text class="plan-meta">从推荐场景开始练习</text>
          </view>
        </view>
        <view class="plan-item">
          <text class="plan-num">03</text>
          <view>
            <text class="plan-title">每日精听 + 跟读</text>
            <text class="plan-meta">提升听力辨音和表达</text>
          </view>
        </view>
      </view>
    </view>

    <view class="scenario-section" wx:if="{{scenarioTags.length > 0}}">
      <text class="section-title">推荐场景</text>
      <view class="scenario-tags">
        <text wx:for="{{scenarioTags}}" wx:key="id" class="chip chip-indigo">{{item.label}}</text>
      </view>
      <view class="estimate">预计学习周期：{{result.recommendations.estimated_study_days}} 天</view>
    </view>

    <view class="result-spacer"></view>
  </view>

  <view class="action-dock" wx:if="{{result}}">
    <button class="start-plan-btn" bindtap="generatePlan">开启学习计划</button>
  </view>

  <view class="result-loading" wx:else>
    <text>正在加载结果...</text>
  </view>

  <view wx:if="{{showDimensionDetail}}" class="dimension-overlay show" bindtap="closeDimensionDetail">
    <view class="dimension-sheet {{dimensionSheetClass}}" catchtap="">
      <view class="sheet-header">
        <view class="sheet-handle"></view>
        <view class="sheet-title-row">
          <view class="sheet-dot" style="background: {{selectedDimension.color}};"></view>
          <text class="sheet-title">{{selectedDimension.label}}</text>
          <text class="sheet-level">{{selectedDimension.level}}</text>
        </view>
        <view class="sheet-close" bindtap="closeDimensionDetail">×</view>
      </view>

      <view class="sheet-body">
        <view class="sheet-stats">
          <view class="stat-item">
            <text class="stat-value">{{selectedDimension.accuracyPercent}}%</text>
            <text class="stat-label">准确率</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{selectedDimension.abilityDisplay}}</text>
            <text class="stat-label">能力值</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{selectedDimension.level}}</text>
            <text class="stat-label">CEFR</text>
          </view>
        </view>

        <view class="sheet-section">
          <text class="sheet-section-title">维度说明</text>
          <text class="sheet-section-text">{{selectedDimension.description}}</text>
        </view>

        <view class="sheet-section">
          <text class="sheet-section-title">学习建议</text>
          <view class="suggestion-list">
            <view class="suggestion-item" wx:for="{{selectedDimension.suggestions}}" wx:key="*this">
              <text class="suggestion-bullet">•</text>
              <text class="suggestion-text">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
