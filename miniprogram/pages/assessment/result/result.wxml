<view class="assessment-result">
  <!-- 等级徽章 -->
  <view class="badge-section">
    <view class="badge-container {{showBadge ? 'show' : ''}}">
      <view class="badge-circle level-{{result.overall_level}}">
        <text class="badge-level">{{result.overall_level}}</text>
      </view>
      <text class="badge-label">你的英语水平</text>
    </view>

    <view class="score-info">
      <text class="score-value">{{result.ability_score}}</text>
      <text class="score-label">能力值</text>
    </view>
  </view>

  <!-- 雷达图 -->
  <view class="radar-section">
    <view class="section-title">能力维度分析</view>
    <canvas
      canvas-id="radarCanvas"
      id="radarCanvas"
      class="radar-canvas"
      bindtouchstart="onRadarTap"
    ></canvas>

    <view class="dimension-legend">
      <view class="legend-item" wx:for="{{dimensionList}}" wx:key="name">
        <view class="legend-dot" style="background: {{item.color}};"></view>
        <text class="legend-name">{{item.label}}</text>
        <text class="legend-value">{{item.level}}</text>
      </view>
    </view>
  </view>

  <!-- 维度详情 -->
  <view class="details-section">
    <view class="section-title">详细分析</view>

    <view class="detail-item" wx:for="{{dimensionList}}" wx:key="name">
      <view class="detail-header">
        <text class="detail-name">{{item.label}}</text>
        <text class="detail-level level-{{item.level}}">{{item.level}}</text>
      </view>
      <view class="detail-progress">
        <view class="progress-bar">
          <view
            class="progress-fill"
            style="width: {{item.accuracy * 100}}%; background: {{item.color}};"
          ></view>
        </view>
        <text class="progress-text">准确率 {{item.accuracyPercent}}%</text>
      </view>
    </view>
  </view>

  <!-- 薄弱环节 -->
  <view class="weak-areas-section" wx:if="{{result.weak_areas && result.weak_areas.length > 0}}">
    <view class="section-title">
      <text class="icon">⚠️</text>
      <text>需要加强</text>
    </view>

    <view class="area-tags">
      <view class="area-tag weak" wx:for="{{result.weak_areas}}" wx:key="*this">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 优势领域 -->
  <view class="strong-areas-section" wx:if="{{result.strong_areas && result.strong_areas.length > 0}}">
    <view class="section-title">
      <text class="icon">✨</text>
      <text>优势领域</text>
    </view>

    <view class="area-tags">
      <view class="area-tag strong" wx:for="{{result.strong_areas}}" wx:key="*this">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 推荐场景 -->
  <view class="recommendations-section">
    <view class="section-title">为你推荐的学习场景</view>

    <view class="scenario-cards">
      <view
        class="scenario-card"
        wx:for="{{result.recommendations.suggested_scenarios}}"
        wx:key="*this"
      >
        <text class="scenario-icon">📚</text>
        <text class="scenario-name">{{item}}</text>
      </view>
    </view>

    <view class="study-estimate">
      <text class="estimate-label">预计学习周期:</text>
      <text class="estimate-value">{{result.recommendations.estimated_study_days}} 天</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="generate-plan-btn" type="primary" bindtap="generatePlan">
      生成专属学习计划
    </button>
    <button class="view-history-btn" bindtap="viewHistory">
      查看历史评估
    </button>
  </view>
</view>
