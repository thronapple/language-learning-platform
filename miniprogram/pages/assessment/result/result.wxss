.assessment-result {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 30%, #f5f7fa 30%);
  padding-bottom: 40rpx;
}

/* 等级徽章区 */
.badge-section {
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  opacity: 0;
  transform: scale(0.5);
  transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.badge-container.show {
  opacity: 1;
  transform: scale(1);
}

.badge-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  margin-bottom: 20rpx;
  position: relative;
}

.badge-circle::before {
  content: '';
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.2;
  }
}

.badge-level {
  font-size: 64rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.badge-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.score-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 24rpx 60rpx;
  backdrop-filter: blur(10rpx);
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  line-height: 1.2;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 雷达图区 */
.radar-section {
  background: white;
  border-radius: 24rpx;
  margin: 0 40rpx 30rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.section-title .icon {
  margin-right: 12rpx;
}

.radar-canvas {
  width: 100%;
  height: 500rpx;
  margin-bottom: 30rpx;
}

.dimension-legend {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.legend-name {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.legend-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

/* 详细分析区 */
.details-section {
  background: white;
  border-radius: 24rpx;
  margin: 0 40rpx 30rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.detail-item {
  margin-bottom: 30rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.detail-level {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #f0f2f5;
  color: #667eea;
}

.detail-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f2f5;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 1s ease-out;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  min-width: 100rpx;
  text-align: right;
}

/* 薄弱/优势领域 */
.weak-areas-section,
.strong-areas-section {
  background: white;
  border-radius: 24rpx;
  margin: 0 40rpx 30rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.area-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.area-tag {
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.area-tag.weak {
  background: #fff3f3;
  color: #ff6b6b;
  border: 2rpx solid #ffe0e0;
}

.area-tag.strong {
  background: #f0fdf4;
  color: #10b981;
  border: 2rpx solid #d1fae5;
}

/* 推荐场景 */
.recommendations-section {
  background: white;
  border-radius: 24rpx;
  margin: 0 40rpx 30rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.scenario-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.scenario-card {
  flex: 0 0 calc(50% - 10rpx);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
}

.scenario-icon {
  font-size: 48rpx;
}

.scenario-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
}

.study-estimate {
  background: #f8f9ff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
}

.estimate-label {
  font-size: 28rpx;
  color: #666;
}

.estimate-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
}

/* 操作按钮 */
.actions {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.generate-plan-btn {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.view-history-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}
