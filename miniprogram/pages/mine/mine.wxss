/* 个人中心页面样式 */
.mine-page {
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: var(--primary-color);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.user-info {
  flex: 1;
}

/* 统计卡片 */
.stats-card {
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  padding: 16rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 菜单卡片 */
.menu-card {
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 16rpx;
  border-radius: 12rpx;
  transition: background-color 0.2s ease;
}

.menu-item:hover {
  background-color: var(--bg-secondary);
}

.menu-icon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  color: var(--text-secondary);
  font-size: 24rpx;
}

/* 页脚链接 */
.footer-links {
  text-align: center;
  padding: 40rpx 0 20rpx;
  margin-top: 40rpx;
}

.link-text {
  color: var(--text-secondary);
  font-size: 24rpx;
  text-decoration: underline;
}

.link-divider {
  color: var(--text-secondary);
  font-size: 24rpx;
  margin: 0 16rpx;
}

/* 辅助类 */
.mb-lg {
  margin-bottom: 32rpx;
}
