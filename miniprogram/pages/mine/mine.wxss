.page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 48rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.user-motto {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 统计卡片 */
.stats-card {
  background: white;
  margin: -20rpx 32rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.12);
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f2f5;
}

/* 菜单 */
.menu-section {
  padding: 0 32rpx;
}

.menu-card {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  transition: background 0.2s ease;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-icon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  margin-left: 16rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.menu-divider {
  height: 1rpx;
  background: #f0f2f5;
  margin-left: 76rpx;
}
