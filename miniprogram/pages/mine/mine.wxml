<view class="container mine-page">
  <!-- 用户信息卡片 -->
  <view class="card user-card">
    <view class="user-avatar">👤</view>
    <view class="user-info">
      <view class="title-medium">语言学习者</view>
      <view class="caption mt-xs">坚持每日学习</view>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="card stats-card">
    <view class="title-medium mb-lg">学习统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{Math.floor(secsToday / 60)}}</view>
        <view class="stat-label">今日分钟</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{streak}}</view>
        <view class="stat-label">连续天数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">100%</view>
        <view class="stat-label">完成率</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card menu-card">
    <view class="title-medium mb-lg">更多功能</view>
    <view class="menu-item" bindtap="goUpgrade">
      <view class="menu-icon">⭐</view>
      <view class="menu-text">升级权益</view>
      <view class="menu-arrow">></view>
    </view>
  </view>

  <!-- 页脚链接 -->
  <view class="footer-links">
    <text class="link-text" bindtap="goPrivacy">隐私政策</text>
    <text class="link-divider">|</text>
    <text class="link-text" bindtap="goTerms">用户协议</text>
  </view>
</view>
