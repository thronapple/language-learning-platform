<view class="page">
  <!-- 头部用户信息 -->
  <view class="header">
    <view class="avatar">👤</view>
    <view class="user-info">
      <view class="user-name">语言学习者</view>
      <view class="user-motto">坚持每日学习</view>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-value">{{secsToday >= 60 ? Math.floor(secsToday / 60) : secsToday}}</view>
      <view class="stat-label">{{secsToday >= 60 ? '今日分钟' : '今日秒数'}}</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{streak}}</view>
      <view class="stat-label">连续天数</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="goImport">
        <text class="menu-icon">📥</text>
        <text class="menu-text">导入内容</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goExport">
        <text class="menu-icon">🖼️</text>
        <text class="menu-text">成果分享</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goUpgrade">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">升级 Pro</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-item" bindtap="goPrivacy">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私政策</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goTerms">
        <text class="menu-icon">📄</text>
        <text class="menu-text">用户协议</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部留白给 tabBar -->
  <view style="height: calc(120rpx + env(safe-area-inset-bottom))"></view>
</view>
