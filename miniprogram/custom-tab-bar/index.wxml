<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon">{{selected === index ? item.iconSelected : item.icon}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
