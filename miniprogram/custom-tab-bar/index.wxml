<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon tab-icon-{{item.iconClass}}">
      <view class="tab-line"></view>
    </view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
